# ============================================================
# ERP Analysis Agent - 环境变量模板
# 复制为 .env 后填入实际值
# ============================================================

# ---- 敏感凭证（必填） ----
LLM_API_KEY=
NEO4J_PASSWORD=
POSTGRES_PASSWORD=

# ---- LLM 配置（可选，覆盖 config.yaml 默认值） ----
# LLM_PROVIDER=zhipu
# LLM_MODEL=glm-4
# LLM_API_BASE=https://open.bigmodel.cn/api/paas/v4

# ---- Neo4j（可选） ----
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USERNAME=neo4j

# ---- PostgreSQL（可选） ----
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DATABASE=eragent
# POSTGRES_USERNAME=postgres
